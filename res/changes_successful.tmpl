<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Settings Saved</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background: #f4f7f8;
            color: #333;
            padding: 20px;
        }

        .container {
            max-width: 500px;
            margin: auto;
            background: #ffffff;
            padding: 30px;
            border-radius: 10px;
            box-shadow: 0 0 10px rgba(0,0,0,0.1);
            text-align: center;
        }

        h2 {
            color: #4CAF50;
            font-size: 24px;
        }

        .note {
            margin-top: 20px;
            font-size: 14px;
            color: #777;
        }

        /* Responsive design for mobile devices */
        @media (max-width: 600px) {
            .container {
                padding: 50px 40px;
            }

            h2 {
                font-size: 32px;
            }

            .note {
                font-size: 24px;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <h2>✅ Settings Saved Successfully</h2>
        <p class="note">The settings have been changed successfully. The device is going to reboot now to apply the new changes.</p>
    </div>
</body>
</html>
